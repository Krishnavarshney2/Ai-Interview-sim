# ============================================
# REQUIRED: AI / LLM Configuration
# ============================================
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ============================================
# REQUIRED: Supabase Configuration
# Get from: https://app.supabase.com/project/_/settings/api
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# REQUIRED for file uploads and admin operations
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=resumes

# ============================================
# REQUIRED: Database Configuration
# For local dev with Docker: postgresql+asyncpg://postgres:postgres@localhost:5432/luminal_ai
# For Supabase: postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/luminal_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# REQUIRED: Redis Configuration
# For local dev with Docker: redis://localhost:6379/0
# For Upstash/Redis Cloud: rediss://default:[password]@[host]:[port]
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Optional: Application Configuration
# ============================================
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Optional: Model / Feature Configuration
# ============================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
DUPLICATE_THRESHOLD=0.75
DEFAULT_ROUNDS=5
MAX_DUPLICATE_RETRIES=3
RESUME_TEXT_LIMIT=4000
RESUME_PARSE_RETRIES=3
ATTENTION_TRACK_DURATION=6
MIN_ATTENTION_SCORE=50
WHISPER_MODEL=base
TTS_LANGUAGE=en
